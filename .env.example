# ══════════════════════════════════════════════════════════
# HITL Lab — Variables de entorno
# Copia este archivo como .env y llena tus keys
# NUNCA subas .env a GitHub
# ══════════════════════════════════════════════════════════

# ── Proveedor activo ──────────────────────────────────────
# Opciones: claude | watsonx | bedrock | gemini | openai
PROVIDER=claude

# ── Anthropic / Claude ────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── IBM WatsonX ───────────────────────────────────────────
WATSONX_API_KEY=
WATSONX_PROJECT_ID=
WATSONX_URL=https://us-south.ml.cloud.ibm.com

# ── AWS Bedrock ───────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=anthropic.claude-3-sonnet-20240229-v1:0

# ── Google Gemini ─────────────────────────────────────────
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-1.5-pro

# ── OpenAI ────────────────────────────────────────────────
OPENAI_API_KEY=

# ── Redis caché (ISO 22301 fallback) ─────────────────────
REDIS_URL=redis://cache:6379/0
CACHE_TTL_SECONDS=3600

# ── ISO Audit Log ─────────────────────────────────────────
AUDIT_LOG_ENABLED=true
AUDIT_LOG_PATH=/home/jovyan/data/audit.jsonl
